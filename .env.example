# Copy to .env and fill. Only ANTHROPIC_API_KEY is required for the default run.
ANTHROPIC_API_KEY=sk-ant-...

# --- Engines to query (comma-separated). Only engines with a ready adapter +
#     key actually run; the rest are skipped with a warning.
#     Adapters wired: claude, openai (ChatGPT), perplexity, gemini.
#     e.g. ENGINES=claude,openai,perplexity,gemini ---
ENGINES=claude

# --- Other answer engines (optional; each engine is skipped unless its key is set) ---
OPENAI_API_KEY=                 # ChatGPT — Responses API + web_search
OPENAI_MODEL=gpt-4o
PERPLEXITY_API_KEY=             # Perplexity — citation-native
PERPLEXITY_MODEL=sonar-pro
GEMINI_API_KEY=                 # Gemini / AI Overviews — generateContent + google_search
GEMINI_MODEL=gemini-2.5-flash

# --- Models ---
# The "answer engine" that gets asked the prompts (what we measure visibility in).
COLLECTION_MODEL=claude-opus-4-8
# The extraction/analysis model (high volume, cost-sensitive). Bump to opus for max quality.
EXTRACTION_MODEL=claude-haiku-4-5

# --- Collection behaviour ---
RESPONSES_PER_PROMPT=1          # query each prompt N times (de-noises engine variance)
USE_WEB_SEARCH=1                # 1 = answer engine may search the web (real citations)
WEB_SEARCH_MAX_USES=5
COLLECTION_MAX_TOKENS=4000

# --- Analysis behaviour ---
RATE_LIMIT_SLEEP=0.0            # seconds between extraction calls (raise if rate-limited)

# --- IO ---
CONFIG_PATH=./config/risa.yaml
PROMPTS_PATH=./prompts/risa_prompts.csv
OUTPUT_DIR=./output
