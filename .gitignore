# secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem

# python
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# node / next
web/node_modules/
web/.next/
web/.vercel/
web/tsconfig.tsbuildinfo
node_modules/

# os / editor
.DS_Store
*.log

# runtime job state (regenerated)
web/data/jobs/

# pipeline output — large JSON/CSV, regenerated on each run
output/
prompts/

# local user config (keyword/competitor choices, not shared)
web/data/app-config.json
web/data/state.json

# bundled data snapshot (rebuilt at deploy time)
web/data/output/
